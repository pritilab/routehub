# Copy to .env and adjust. docker compose reads this automatically.

# --- Postgres ---
POSTGRES_DB=routehub
POSTGRES_USER=routehub
POSTGRES_PASSWORD=routehub
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Django / FastAPI ---
# Host port for the API (container always listens on 8000)
BACKEND_PORT=8000
SECRET_KEY=change-me-in-production
DEBUG=1
ALLOWED_HOSTS=*
JWT_SECRET=change-me-too
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=14

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0

# --- Search / Cache ---
MEILI_MASTER_KEY=dev-meili-master-key-not-for-prod
POI_LIST_CACHE_TTL=60

# --- Embeddings (semantic search) ---
# hash = instant dev backend; fastembed = real ONNX model (downloads ~100MB on first use)
EMBEDDING_BACKEND=hash
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- Routing / Geo ---
# Leave empty to use straight-line fallback instead of OSRM
OSRM_URL=
NOMINATIM_URL=https://nominatim.openstreetmap.org

# --- Frontend ---
VITE_API_BASE=/api/v1
VITE_MAPBOX_TOKEN=
